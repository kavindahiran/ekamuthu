// ============================================================
//  The Dinner Club LK — Prisma Schema v7
//  PostgreSQL
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Connection URL is configured in prisma.config.ts (Prisma 7 requirement)
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  GUEST
  HOST
  ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum DietaryTag {
  STRICT_BUDDHIST_VEG
  HINDU_VEG
  VEGAN
  LACTO_VEGETARIAN
  HALAL
  NO_BEEF
  NO_PORK
  REGULAR_NON_VEG
  JAIN
  GLUTEN_FREE
  NUT_FREE
}

enum CuisineType {
  SRI_LANKAN
  SOUTH_INDIAN
  NORTH_INDIAN
  CHINESE
  WESTERN
  MIDDLE_EASTERN
  FUSION
  OTHER
}

enum ListingStatus {
  DRAFT
  ACTIVE
  FULL
  CANCELLED
  COMPLETED
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
  CANCELLED
  ATTENDED
  NO_SHOW
}

enum ReviewType {
  GUEST_REVIEWS_HOST
  HOST_REVIEWS_GUEST
}

enum PaymentMethod {
  CARD
  MOBILE_WALLET
  BANK_TRANSFER
}

enum MobileWalletProvider {
  FRIMI
  GENIE
  PAYHERE_WALLET
  OTHER
}

enum PaymentGateway {
  PAYHERE
  WEBXPAY
  MANUAL
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum GenderPolicy {
  NONE
  FEMALE_ONLY
  MALE_ONLY
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String
  displayName   String?
  avatarUrl     String?
  bio           String?   @db.Text
  role          UserRole  @default(GUEST)
  isActive      Boolean   @default(true)

  phone             String?   @unique
  phoneVerified     Boolean   @default(false)
  phoneOtp          String?
  phoneOtpExpiresAt DateTime?

  nicNumber            String?
  passportNumber       String?
  idDocumentUrl        String?
  idVerificationStatus VerificationStatus @default(UNVERIFIED)
  idVerifiedAt         DateTime?
  idVerifiedByAdminId  String?

  instagramUrl String?
  linkedinUrl  String?
  facebookUrl  String?

  isHostEligible Boolean   @default(false)
  hostSince      DateTime?

  dietaryPreferences DietaryTag[]

  avgRatingAsHost     Float @default(0)
  avgRatingAsGuest    Float @default(0)
  totalReviewsAsHost  Int   @default(0)
  totalReviewsAsGuest Int   @default(0)

  dinnerListings   DinnerListing[]  @relation("HostListings")
  bookings         Booking[]        @relation("GuestBookings")
  reviewsGiven     Review[]         @relation("ReviewsGiven")
  reviewsReceived  Review[]         @relation("ReviewsReceived")
  dinnerQuestions  DinnerQuestion[]
  accounts         Account[]
  sessions         Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([idVerificationStatus])
  @@index([isHostEligible])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── DinnerListing ────────────────────────────────────────────────────────────

model DinnerListing {
  id     String @id @default(cuid())
  hostId String

  title         String
  description   String      @db.Text
  cuisineType   CuisineType
  menuItems     String[]
  coverImageUrl String?
  imageUrls     String[]

  dietaryTags  DietaryTag[]
  dietaryNotes String?      @db.Text

  totalSeats      Int
  seatsAvailable  Int
  pricePerSeatLKR Decimal @db.Decimal(10, 2)

  dinnerDate   DateTime
  doorOpenTime DateTime
  endTime      DateTime

  area        String
  city        String
  addressHint String?
  latitude    Float?
  longitude   Float?

  status             ListingStatus @default(DRAFT)
  genderPolicy       GenderPolicy  @default(NONE)
  minimumAge         Int?
  maxSeatsPerBooking Int           @default(1)
  cancellationPolicy String?       @db.Text

  host      User             @relation("HostListings", fields: [hostId], references: [id])
  bookings  Booking[]
  reviews   Review[]
  questions DinnerQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city, status, dinnerDate])
  @@index([area, status, dinnerDate])
  @@index([status, dinnerDate])
  @@index([hostId, status])
  @@index([pricePerSeatLKR])
}

// ─── Booking ──────────────────────────────────────────────────────────────────

model Booking {
  id        String @id @default(cuid())
  guestId   String
  listingId String

  status         BookingStatus @default(PENDING)
  introMessage   String        @db.Text
  seatsRequested Int           @default(1)

  hostResponseMessage String?   @db.Text
  respondedAt         DateTime?

  cancelledById      String?
  cancelledAt        DateTime?
  cancellationReason String?   @db.Text

  guest   User          @relation("GuestBookings", fields: [guestId], references: [id])
  listing DinnerListing @relation(fields: [listingId], references: [id])
  payment Payment?
  reviews Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([guestId, listingId])
  @@index([guestId, status])
  @@index([listingId, status])
  @@index([status, createdAt])
}

// ─── Review ───────────────────────────────────────────────────────────────────

model Review {
  id         String @id @default(cuid())
  reviewerId String
  revieweeId String
  bookingId  String
  listingId  String

  type     ReviewType
  rating   Int
  comment  String     @db.Text
  isPublic Boolean    @default(true)

  reviewer User          @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewee User          @relation("ReviewsReceived", fields: [revieweeId], references: [id])
  booking  Booking       @relation(fields: [bookingId], references: [id])
  listing  DinnerListing @relation(fields: [listingId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([reviewerId, bookingId])
  @@index([revieweeId, type])
  @@index([listingId])
}

// ─── Payment ──────────────────────────────────────────────────────────────────

model Payment {
  id        String @id @default(cuid())
  bookingId String @unique

  amountLKR   Decimal @db.Decimal(10, 2)
  platformFee Decimal @default(0) @db.Decimal(10, 2)

  paymentMethod        PaymentMethod
  mobileWalletProvider MobileWalletProvider?
  paymentGateway       PaymentGateway?

  gatewayOrderId  String?
  transactionRef  String? @unique
  gatewayResponse Json?

  receiptUrl String?
  bankRef    String?
  bankName   String?

  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?
  failureReason String?

  refundedAt      DateTime?
  refundRef       String?
  refundAmountLKR Decimal?  @db.Decimal(10, 2)

  booking Booking @relation(fields: [bookingId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([transactionRef])
  @@index([paymentGateway, status])
}

// ─── DinnerQuestion ───────────────────────────────────────────────────────────
// Pre-dinner community board: guests & host exchange questions before the event.

model DinnerQuestion {
  id        String @id @default(cuid())
  listingId String
  authorId  String

  body      String  @db.Text
  replyBody String? @db.Text // Host reply
  repliedAt DateTime?
  isPinned  Boolean @default(false)

  listing DinnerListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  author  User          @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId, createdAt])
}
